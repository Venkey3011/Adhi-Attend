# Node environment - set to "production" on Render
NODE_ENV=production

# Port - Render sets this automatically, default 3000
PORT=3000

# GEMINI_API_KEY: Required for Gemini AI features.
# Add this in Render Dashboard → Environment → Add Environment Variable
GEMINI_API_KEY=your_gemini_api_key_here

# MONGODB_URI: MongoDB Atlas connection string.
# Add this in Render Dashboard → Environment → Add Environment Variable
# Ensure IP 0.0.0.0/0 is whitelisted in MongoDB Atlas Network Access.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/college_attendance?retryWrites=true&w=majority
